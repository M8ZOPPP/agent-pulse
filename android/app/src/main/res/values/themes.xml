<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AgentPulse" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/canvas</item>
        <item name="android:statusBarColor">@color/canvas</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent</item>
        <item name="colorOnPrimary">@color/accent_dark</item>
        <item name="colorSecondary">@color/question</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/ink</item>
        <item name="android:windowBackground">@color/canvas</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="materialButtonStyle">@style/Widget.AgentPulse.Button</item>
        <item name="textInputStyle">@style/Widget.AgentPulse.TextInput</item>
    </style>

    <style name="Widget.AgentPulse.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">14dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.AgentPulse.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="boxStrokeColor">@color/line</item>
        <item name="hintTextColor">@color/ink_muted</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
    </style>
</resources>
